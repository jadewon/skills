# data.go.kr 일반 인증키 (URL-encoded). 아래 3개 서비스 활용신청 필요:
#   - 기상청_단기예보 조회서비스 (VilageFcstInfoService_2.0)
#   - 한국환경공단_에어코리아_대기오염정보 (ArpltnInforInqireSvc)
#   - 기상청_생활기상지수 조회서비스 (LivingWthrIdxServiceV4)
KMA_SERVICE_KEY=

# Slack incoming webhook URL (채널 고정형)
SLACK_WEBHOOK_URL=

# 위치 — KMA 격자 좌표 (위경도 → 격자 변환 필요, https://www.weather.go.kr 참고)
# 기본값은 서울시청 (37.5666791, 126.9782914) 근처
NX=60
NY=127

# 생활기상지수 areaNo — 시군구 단위 10자리 행정구역코드 (동 단위 안 됨)
# 예: 서울 중구 1114000000, 서울 강남구 1168000000
AREA_NO=1114000000

# (선택) 공휴일 체크 API endpoint. 비우면 공휴일에도 발송.
# 응답이 빈 배열([])이면 평일, 그 외면 공휴일로 간주.
HOLIDAY_API_URL=
