# Slack User OAuth Token (xoxp-...) — files.getUploadURLExternal/completeUploadExternal/files.delete 는 user 토큰 필요.
# slack-edit-message 와 같은 Slack App / 같은 토큰 재사용 가능. 공유 토큰 파일
# ~/.config/slack-user-token/.env 에 저장해두면 이 스킬도 자동으로 찾는다.
#
# 발급: https://api.slack.com/apps → 앱 선택 → OAuth & Permissions → User Token Scopes: files:write
SLACK_USER_TOKEN=
